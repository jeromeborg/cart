{
    "name": "jeromeborg/cart",
    "description": "A complete cart for Laravel",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/session": "^12.0|^13.0",
        "illuminate/events": "^12.0|^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.5.1",
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.0|^10.5|^11.0"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Jeromeborg\\Cart\\": "src/"
        }
    },
    "authors": [
        {
            "name": "jeromeborg",
            "email": "contact@jeromeb.org"
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Jeromeborg\\Cart\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jeromeborg\\Cart\\CartServiceProvider"
            ],
            "aliases": {
                "Cart": "Jeromeborg\\Cart\\Facades\\Cart"
            }
        }
    },
    "minimum-stability": "stable"
}
